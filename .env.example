# Day 10 Lab — copy thành .env và điền nếu cần
#   cp .env.example .env

# ChromaDB (khuyến nghị tách collection khỏi Day 09)
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day10_kb

# Embedding (SentenceTransformers — offline)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Freshness SLA theo boundary (giờ)
# ingest: độ mới của nguồn export
FRESHNESS_SLA_INGEST_HOURS=24
# publish: độ mới của lần pipeline publish gần nhất
FRESHNESS_SLA_PUBLISH_HOURS=2

# Backward-compatible fallback cho code cũ chỉ đọc 1 SLA
FRESHNESS_SLA_HOURS=24

# Tuỳ chọn override ngưỡng versioning HR (định dạng YYYY-MM-DD)
# HR_LEAVE_MIN_EFFECTIVE_DATE=2026-01-01

# Tuỳ chọn: OpenAI chỉ cần nếu nhóm mở rộng eval bằng LLM-judge
# OPENAI_API_KEY=
